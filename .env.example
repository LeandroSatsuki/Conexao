APP_NAME=Preferenza Connector
APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://preferenza:preferenza@localhost:5432/preferenza
REDIS_URL=redis://localhost:6379/0
FERNET_KEY=replace-with-generated-fernet-key

API_V1_PREFIX=/api/v1
CORS_ORIGINS=*
DEFAULT_TENANT_ID=preferenza

POSTGRES_DB=preferenza
POSTGRES_USER=preferenza
POSTGRES_PASSWORD=preferenza
POSTGRES_PORT=5432

SANKHYA_TIMEOUT_SECONDS=30

