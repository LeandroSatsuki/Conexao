APP_NAME=Preferenza Connector
APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://preferenza:preferenza@localhost:5432/preferenza
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false
CELERY_TASK_DEFAULT_QUEUE=preferenza
FERNET_KEY=replace-with-generated-fernet-key

API_V1_PREFIX=/api/v1
CORS_ORIGINS=*
DEFAULT_TENANT_ID=preferenza

POSTGRES_DB=preferenza
POSTGRES_USER=preferenza
POSTGRES_PASSWORD=preferenza
POSTGRES_PORT=5432

SANKHYA_TIMEOUT_SECONDS=30
SANKHYA_AUTH_TIMEOUT_SECONDS=30
SANKHYA_SANDBOX_BASE_URL=https://api.sandbox.sankhya.com.br
SANKHYA_PRODUCTION_BASE_URL=https://api.sankhya.com.br
SANKHYA_DEFAULT_ENVIRONMENT=sandbox
SANKHYA_READ_TEST_ENTITY=
SANKHYA_READ_TEST_FIELDS=
SANKHYA_READ_TEST_LIMIT=1

CONNECTOR_API_BASE_URL=http://localhost:8000
VALIDATION_TENANT_NAME=Preferenza Homologacao
SANKHYA_VALIDATION_CONNECTION_NAME=Sankhya Sandbox Validation
VALIDATION_POLL_INTERVAL_SECONDS=1
VALIDATION_MAX_POLL_ATTEMPTS=120
VALIDATION_REPORT_DIR=backend/reports
